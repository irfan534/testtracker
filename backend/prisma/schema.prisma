// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Organization
model Organization {
  id            String      @id @default(cuid())
  name          String
  description   String?
  logo          String?
  website       String?
  industry      String?
  size          String? // small, medium, large, enterprise
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?

  // Relations
  users         User[]
  certifications Certification[]
  frameworks    FrameworkAssociation[]
  uploads       Upload[]
  auditLogs     AuditLog[]

  @@index([deletedAt])
}

// User
model User {
  id                String      @id @default(cuid())
  email             String      @unique
  password          String
  firstName         String
  lastName          String
  avatar            String?
  role              UserRole    @default(VIEWER)
  department        String?
  phone             String?
  status            UserStatus  @default(ACTIVE)
  
  // Security
  emailVerified     Boolean     @default(false)
  emailVerifiedAt   DateTime?
  mfaEnabled        Boolean     @default(false)
  mfaSecret         String?
  backupCodes       String[]
  lastLoginAt       DateTime?
  lastLoginIp       String?
  lastLoginDevice   String?
  passwordChangedAt DateTime?
  failedLoginAttempts Int       @default(0)
  lockedUntil       DateTime?

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  deletedAt         DateTime?

  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Relations
  sessions          Session[]
  certifications    Certification[]
  auditLogs         AuditLog[]
  refreshTokens     RefreshToken[]
  uploads           Upload[]

  @@index([organizationId])
  @@index([email])
  @@index([status])
  @@index([deletedAt])
}

// User Roles
enum UserRole {
  SUPER_ADMIN
  COMPLIANCE_MANAGER
  AUDITOR
  VIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED
  PENDING_VERIFICATION
}

// Session
model Session {
  id              String      @id @default(cuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Device & IP tracking
  ipAddress       String
  userAgent       String?
  deviceType      String?
  
  // Timing
  createdAt       DateTime    @default(now())
  expiresAt       DateTime
  lastActivityAt  DateTime    @default(now())
  
  // Relations
  refreshTokens   RefreshToken[]
  
  @@index([userId])
  @@index([expiresAt])
}

// Refresh Token (for secure token rotation)
model RefreshToken {
  id              String      @id @default(cuid())
  token           String      @unique
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId       String?
  session         Session?     @relation(fields: [sessionId], references: [id])
  
  expiresAt       DateTime
  revokedAt       DateTime?
  
  createdAt       DateTime    @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@index([sessionId])
}

// Certification
model Certification {
  id              String      @id @default(cuid())
  name            String
  certificateId   String      @unique
  certificateType String      // ISO 27001, SOC 2, HIPAA, etc.
  
  // Dates
  issueDate       DateTime
  expiryDate      DateTime
  validityDays    Int
  renewalReminderDays Int @default(30)
  
  // Details
  issuingBody     String
  owner           String?
  department      String?
  description     String?
  
  // Status
  status          CertificationStatus @default(ACTIVE)
  renewalStatus   RenewalStatus @default(ACTIVE)
  
  // Files
  logoUrl         String?
  evidenceUrls    String[]
  
  // Framework mapping
  frameworks      FrameworkCertification[]
  
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?

  // Relations
  uploads         Upload[]
  auditLogs       AuditLog[]

  @@index([organizationId])
  @@index([expiryDate])
  @@index([status])
  @@index([deletedAt])
  @@index([issuingBody])
  @@index([certificateType])
}

enum CertificationStatus {
  ACTIVE
  EXPIRING_SOON
  EXPIRED
  RENEWAL_IN_PROGRESS
  SUSPENDED
}

enum RenewalStatus {
  ACTIVE
  RENEWAL_DUE
  RENEWAL_IN_PROGRESS
  RENEWED
  LAPSED
}

// Compliance Framework
model Framework {
  id              String      @id @default(cuid())
  name            String      @unique
  description     String?
  type            String      // ISO, SOC, HIPAA, etc.
  
  certifications  FrameworkCertification[]
  associations    FrameworkAssociation[]
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([name])
}

// Framework to Certification mapping
model FrameworkCertification {
  id              String      @id @default(cuid())
  
  frameworkId     String
  framework       Framework   @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  
  certificationId String
  certification   Certification @relation(fields: [certificationId], references: [id], onDelete: Cascade)
  
  mappedAt        DateTime    @default(now())
  
  @@unique([frameworkId, certificationId])
  @@index([frameworkId])
  @@index([certificationId])
}

// Organization Framework Association
model FrameworkAssociation {
  id              String      @id @default(cuid())
  
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  frameworkId     String
  framework       Framework   @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  
  maturityLevel   Int         @default(0)
  compliancePercentage Float  @default(0)
  owner           String?
  reviewSchedule  String?
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([organizationId, frameworkId])
  @@index([organizationId])
  @@index([frameworkId])
}

// File Upload
model Upload {
  id              String      @id @default(cuid())
  fileName        String
  originalName    String
  fileSize        Int
  mimeType        String
  fileType        UploadType
  
  // Storage  
  storagePath     String
  fileUrl         String
  signedUrl       String?
  signedUrlExpiry DateTime?
  
  // Metadata
  uploadedBy      String
  uploadedByUser  User        @relation(fields: [uploadedBy], references: [id])
  
  // Processing
  status          UploadStatus @default(PENDING)
  processedAt     DateTime?
  errorMessage    String?
  
  // Data import
  recordsImported Int         @default(0)
  recordsSkipped  Int         @default(0)
  duplicatesFound Int         @default(0)
  
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  certificationId String?
  certification   Certification? @relation(fields: [certificationId], references: [id])
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([organizationId])
  @@index([fileType])
  @@index([status])
  @@index([createdAt])
}

enum UploadType {
  EXCEL
  CSV
  LOGO
  EVIDENCE
  REPORT
}

enum UploadStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  VIRUS_DETECTED
}

// Report
model Report {
  id              String      @id @default(cuid())
  name            String
  reportType      ReportType
  
  // Data
  data            Json
  summary         String?
  
  organizationId  String
  
  createdAt       DateTime    @default(now())
  generatedAt     DateTime    @default(now())

  @@index([organizationId])
  @@index([reportType])
  @@index([createdAt])
}

enum ReportType {
  EXPIRY_FORECAST
  COMPLIANCE_STATUS
  RENEWAL_TIMELINE
  AUDIT_READINESS
  FRAMEWORK_COVERAGE
}

// Audit Log
model AuditLog {
  id              String      @id @default(cuid())
  action          AuditAction
  entityType      String
  entityId        String?
  
  // Details
  changes         Json?
  details         String?
  
  // User
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  
  // Device & Network
  ipAddress       String?
  userAgent       String?
  deviceType      String?
  
  // Severity
  severity        AuditSeverity @default(INFO)
  
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  certificationId String?
  certification   Certification? @relation(fields: [certificationId], references: [id])
  
  createdAt       DateTime    @default(now())

  @@index([userId])
  @@index([organizationId])
  @@index([action])
  @@index([severity])
  @@index([createdAt])
  @@index([entityType])
}

enum AuditAction {
  AUTH_LOGIN
  AUTH_LOGOUT
  AUTH_LOGIN_FAILED
  AUTH_PASSWORD_CHANGED
  AUTH_MFA_ENABLED
  AUTH_MFA_DISABLED
  USER_CREATED
  USER_UPDATED
  USER_DELETED
  USER_ROLE_CHANGED
  CERT_CREATED
  CERT_UPDATED
  CERT_DELETED
  CERT_EXPORTED
  UPLOAD_STARTED
  UPLOAD_COMPLETED
  UPLOAD_FAILED
  IMPORT_STARTED
  IMPORT_COMPLETED
  IMPORT_FAILED
  REPORT_GENERATED
  REPORT_EXPORTED
}

enum AuditSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

// Notification
model Notification {
  id              String      @id @default(cuid())
  type            NotificationType
  title           String
  message         String
  data            Json?
  read            Boolean     @default(false)
  readAt          DateTime?
  
  organizationId  String
  
  createdAt       DateTime    @default(now())

  @@index([organizationId])
  @@index([type])
  @@index([read])
  @@index([createdAt])
}

enum NotificationType {
  CERT_EXPIRING_SOON
  CERT_EXPIRED
  RENEWAL_DUE
  UPLOAD_COMPLETED
  IMPORT_COMPLETED
  SECURITY_ALERT
}

// Settings
model Setting {
  id              String      @id @default(cuid())
  key             String
  value           String
  description     String?
  
  organizationId  String
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([organizationId, key])
  @@index([organizationId])
}
